---
import Comment from "@components/comment/index.astro";
import { Icon } from "astro-icon/components";
import BangumiEditor from "@/components/edit/BangumiEditor.svelte";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

if (!siteConfig.pages.books) {
	return Astro.redirect("/404/");
}

const title = i18n(I18nKey.booksTitle);
const description = i18n(I18nKey.booksSubtitle);
---

<MainGridLayout title={title} description={description}>
	<div class="books-page-wrapper flex w-full overflow-hidden relative min-h-32">
		<div data-pagefind-body class="card-base z-10 px-6 pt-8 pb-8 relative w-full">
			<header class="books-header relative w-full mb-6 flex justify-between items-start gap-4 flex-wrap">
				<div class="flex-1 min-w-0">
					<div class="flex items-center gap-3 mb-3">
						<div class="w-12 h-12 rounded-2xl bg-black dark:bg-white flex items-center justify-center">
							<Icon name="material-symbols:auto-stories" class="text-[1.4rem] text-white dark:text-black" />
						</div>
						<div>
							<h1 data-pagefind-meta="title" data-pagefind-weight="10" class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">{title}</h1>
						</div>
					</div>
					<p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">{description}</p>
					<div class="flex items-center gap-4 mt-2">
						<p class="text-xs text-neutral-400 dark:text-neutral-500" id="books-update-time"></p>
						<div class="flex items-center gap-3 text-xs text-neutral-500 dark:text-neutral-400" id="books-stats"></div>
					</div>
				</div>
				<div class="page-header-toolbar-slot flex-shrink-0"></div>
			</header>

			<div data-no-swup>
				<BangumiEditor
					client:only
					defaultCategory="book"
					skipDomCollect={true}
					customPageName="书架"
				/>
			</div>

			<div class="bangumi-section" id="books-content">
				<div class="w-full p-12 text-center"><span>加载中...</span></div>
			</div>
		</div>
	</div>
	<Comment customPath="/books/" />
</MainGridLayout>

<script>
	const GH_OWNER = "fqzlr";
	const GH_REPO = "my-blog";
	const BANGUMI_PATH = "public/bangumi.json";

	async function fetchJson(path: string): Promise<any> {
		if (path.startsWith("public/")) {
			try {
				const res = await fetch("/" + path.slice(7));
				if (res.ok) return await res.json();
			} catch {}
		}
		const branch = (typeof window !== 'undefined' && (window as any).__DEPLOY_BRANCH__) || "master";
		const apiPath = `repos/${GH_OWNER}/${GH_REPO}/contents/${path}?ref=${branch}`;
		const res = await fetch("/api/github", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({
				path: apiPath,
				method: "GET",
				headers: { Accept: "application/vnd.github+json" },
			}),
		});
		if (!res.ok) throw new Error("HTTP " + res.status);
		const data = await res.json();
		const text = decodeURIComponent(escape(atob(data.content.replace(/\n/g, ""))));
		return JSON.parse(text);
	}

	function esc(s: string): string {
		const d = document.createElement("div");
		d.textContent = s;
		return d.innerHTML;
	}

	const statusConfig: Record<number, { color: string; label: string }> = {
		1: { color: "#5bc0de", label: "想读" },
		2: { color: "#5cb85c", label: "已读" },
		3: { color: "#f0ad4e", label: "在读" },
		4: { color: "#9b8ec4", label: "搁置" },
		5: { color: "#d9534f", label: "抛弃" },
	};

	function renderBookCard(book: any): string {
		const title = esc(book.title || "");
		const coverImage = esc(book.image || "");
		const status = book.status || 2;
		const score = book.score || 0;
		const link = book.link || "#";
		const sc = statusConfig[status] || { color: "#999", label: "" };
		const scoreText = score > 0 ? `${score}`.replace(/\.0$/, "") : "";

		const scoreHtml = scoreText
			? `<span class="book-score-tag"><svg class="book-score-star" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>${scoreText}</span>`
			: "";

		return `<a href="${esc(link)}" class="book-card group">
			<div class="book-cover-wrap">
				<img src="${coverImage}" alt="${title}" class="book-cover-img" loading="lazy" />
				<span class="book-status-tag" style="background: ${sc.color};">${sc.label}</span>
				${scoreHtml}
				<div class="book-hover-overlay"><span class="book-hover-text">查看详情</span></div>
			</div>
			<p class="book-title">${title}</p>
		</a>`;
	}

	function renderBooks(rawItems: any[]) {
		const el = document.getElementById("books-content");
		if (!el) return;

		const bookItems = rawItems
			.filter((item) => item.category === "book")
			.sort((a, b) => new Date(b.published || 0).getTime() - new Date(a.published || 0).getTime())
			.map((item) => ({
				title: item.title,
				image: typeof item.image === "string" ? item.image : "",
				link: `/books/${item.id || ""}/`,
				status: item.status,
				score: item.score || 0,
			}));

		// Update time
		const timeEl = document.getElementById("books-update-time");
		if (timeEl) {
			const now = new Date();
			timeEl.textContent = `数据更新于 ${now.getFullYear()}/${String(now.getMonth()+1).padStart(2,"0")}/${String(now.getDate()).padStart(2,"0")} ${String(now.getHours()).padStart(2,"0")}:${String(now.getMinutes()).padStart(2,"0")}`;
		}

		// Stats
		const readingCount = bookItems.filter(b => b.status === 3).length;
		const readCount = bookItems.filter(b => b.status === 2).length;
		const wishCount = bookItems.filter(b => b.status === 1).length;
		const statsEl = document.getElementById("books-stats");
		if (statsEl) {
			statsEl.innerHTML = `
				<span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-emerald-500 inline-block"></span>已读 ${readCount}</span>
				<span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-amber-500 inline-block"></span>在读 ${readingCount}</span>
				<span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-sky-500 inline-block"></span>想读 ${wishCount}</span>`;
		}

		if (bookItems.length === 0) {
			el.innerHTML = `<div class="w-full p-12 text-center"><p class="text-neutral-500 dark:text-neutral-400">暂无书籍</p></div>`;
			return;
		}

		let html = '<div class="bookshelf"><div class="shelf-grid">';
		for (const book of bookItems) {
			html += renderBookCard(book);
		}
		html += '</div></div>';
		el.innerHTML = html;
	}

	const el = document.getElementById("books-content");
	if (el) {
		fetchJson(BANGUMI_PATH)
			.then((data) => renderBooks(data))
			.catch((err) => {
				console.error("[Books] Failed to load:", err);
				el.innerHTML = '<div class="w-full p-12 text-center"><p>加载失败，请刷新重试</p></div>';
			});
	}
</script>

<style>
	.books-page-wrapper { border-radius: var(--radius-large); }
	.books-header { animation: fadeSlideIn 0.4s ease both; }
	@keyframes fadeSlideIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

	/* Bookshelf styles */
	:global(.bookshelf) { padding: 24px 16px 8px; border: 2px solid #000; border-radius: 16px; }
	:global(:root.dark .bookshelf) { border-color: #3f3f46; }
	:global(.shelf-grid) { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px 16px; padding: 0 4px; }
	@media (min-width: 640px) { :global(.shelf-grid) { grid-template-columns: repeat(4, 1fr); } }
	@media (min-width: 768px) { :global(.shelf-grid) { grid-template-columns: repeat(5, 1fr); } }
	@media (min-width: 1024px) { :global(.shelf-grid) { grid-template-columns: repeat(6, 1fr); } }
	@media (max-width: 640px) { :global(.bookshelf) { padding: 8px 2px 2px; } :global(.shelf-grid) { gap: 18px 8px; } }

	/* BookCard styles */
	:global(.book-card) { display: block; text-decoration: none; color: inherit; cursor: pointer; transition: transform 0.2s ease; }
	:global(.book-card:hover) { transform: translateY(-4px); }
	:global(:root.dark .book-card:hover .book-title) { color: var(--primary); }
	:global(.book-cover-wrap) { position: relative; aspect-ratio: 3/4; border-radius: 6px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.10), 0 1px 2px rgba(0,0,0,0.06); transition: box-shadow 0.2s ease; background: var(--btn-regular-bg); }
	:global(.book-card:hover .book-cover-wrap) { box-shadow: 0 8px 25px rgba(0,0,0,0.15), 0 2px 6px rgba(0,0,0,0.08); }
	:global(.book-cover-img) { width: 100%; height: 100%; object-fit: cover; display: block; }
	:global(.book-status-tag) { position: absolute; top: 8px; left: 8px; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 600; color: #fff; z-index: 2; letter-spacing: 0.02em; line-height: 1.6; }
	:global(.book-score-tag) { position: absolute; top: 8px; right: 8px; display: flex; align-items: center; gap: 2px; padding: 2px 7px 2px 5px; border-radius: 4px; background: rgba(0,0,0,0.55); font-size: 11px; font-weight: 700; color: #fbbf24; z-index: 2; line-height: 1; }
	:global(.book-score-star) { width: 10px; height: 10px; flex-shrink: 0; }
	:global(.book-hover-overlay) { position: absolute; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s ease; z-index: 3; }
	:global(.book-card:hover .book-hover-overlay) { opacity: 1; }
	:global(.book-hover-text) { color: #fff; font-size: 14px; font-weight: 600; padding: 6px 16px; border: 1.5px solid rgba(255,255,255,0.7); border-radius: 20px; letter-spacing: 0.04em; }
	:global(.book-title) { margin: 8px 2px 0; font-size: 12px; font-weight: 500; line-height: 1.4; color: var(--deep-text); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-align: center; }
	:global(.book-card:hover .book-title) { color: var(--primary); }
	:global(:root.dark .book-cover-wrap) { border: 1px solid #3f3f46; box-shadow: 0 2px 8px rgba(255,255,255,0.03); }
	:global(:root.dark .book-card:hover .book-cover-wrap) { border-color: #fff; box-shadow: 0 8px 25px rgba(255,255,255,0.1); }

	@media (max-width: 768px) { :has(> .page-header-toolbar-slot) { flex-direction: column; } .page-header-toolbar-slot { width: 100%; } }
	@media (max-width: 640px) { .card-base { padding-left: 1rem; padding-right: 1rem; padding-top: 1.5rem; padding-bottom: 1.5rem; } }
</style>
