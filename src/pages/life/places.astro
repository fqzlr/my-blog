---
import { Icon } from "astro-icon/components";
import PlacesEditor from "@/components/edit/PlacesEditor.svelte";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title='去过的地方' description='足迹地图与旅行记录'>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-4 py-6 md:px-9 relative w-full">

      <!-- 头部 -->
      <div class="flex items-center gap-3 mb-6">
        <div class="w-12 h-12 rounded-2xl bg-black dark:bg-white flex items-center justify-center">
          <Icon name="material-symbols:explore" class="text-[1.4rem] text-white dark:text-black" />
        </div>
        <div>
          <h1 data-pagefind-meta="title" data-pagefind-weight="10" class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">去过的地方</h1>
          <p class="text-sm text-neutral-500 dark:text-neutral-400">足迹地图与旅行记录</p>
        </div>
        <div class="page-header-toolbar-slot flex-shrink-0 ml-auto"></div>
      </div>

      <div data-no-swup>
        <PlacesEditor client:only />
      </div>

      <!-- 统计 -->
      <div class="flex flex-wrap gap-3 mb-6" id="places-stats">
        <div class="stat-pill">
          <Icon name="material-symbols:location-city" class="text-sm" />
          <span class="font-semibold">-</span>
          <span class="text-neutral-500 dark:text-neutral-400">地点</span>
        </div>
        <div class="stat-pill">
          <Icon name="material-symbols:pin-drop" class="text-sm" />
          <span class="font-semibold">-</span>
          <span class="text-neutral-500 dark:text-neutral-400">到访次数</span>
        </div>
        <div class="stat-pill">
          <Icon name="material-symbols:calendar-today" class="text-sm" />
          <span class="font-semibold">-</span>
          <span class="text-neutral-500 dark:text-neutral-400">今年出行</span>
        </div>
      </div>

      <!-- 地图 -->
      <div class="mb-6">
        <h2 class="text-lg font-bold text-neutral-900 dark:text-neutral-100 mb-3">足迹地图</h2>
        <div id='life-map' class='h-[500px] w-full rounded-xl border-2 border-black dark:border-[#3f3f46] overflow-hidden'></div>
        <p class='mt-2 text-xs text-neutral-400 dark:text-neutral-500 text-center'>地图由 Apache ECharts 提供</p>
      </div>

      <!-- 地点列表 -->
      <div>
        <h2 class="text-lg font-bold text-neutral-900 dark:text-neutral-100 mb-3">地点列表</h2>
        <div id="places-list">
          <div class='w-full p-12 text-center'>
            <p class='text-neutral-500 dark:text-neutral-400'>加载中...</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</MainGridLayout>

<script>
  const GH_OWNER = "fqzlr";
  const GH_REPO = "my-blog";
  const PLACES_PATH = "public/places.json";

  async function fetchJson(path: string): Promise<any> {
    if (path.startsWith("public/")) {
      try {
        const res = await fetch("/" + path.slice(7));
        if (res.ok) return await res.json();
      } catch {}
    }
    const branch = (typeof window !== 'undefined' && (window as any).__DEPLOY_BRANCH__) || "master";
    const apiPath = `repos/${GH_OWNER}/${GH_REPO}/contents/${path}?ref=${branch}`;
    const res = await fetch("/api/github", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ path: apiPath, method: "GET", headers: { Accept: "application/vnd.github+json" } }),
    });
    if (!res.ok) throw new Error("HTTP " + res.status);
    const data = await res.json();
    const text = decodeURIComponent(escape(atob(data.content.replace(/\n/g, ""))));
    return JSON.parse(text);
  }

  function esc(s: string) { const d = document.createElement("div"); d.textContent = s; return d.innerHTML; }

  function renderPlaces(places: any[]) {
    const now = new Date();
    const currentYear = now.getFullYear();

    // Sort by date desc
    const sorted = [...places].sort((a, b) => {
      const aTime = a.date ? new Date(a.date).getTime() : 0;
      const bTime = b.date ? new Date(b.date).getTime() : 0;
      return bTime - aTime;
    });

    const totalVisitCount = sorted.reduce((acc, p) => acc + (p.visitCount || 1), 0);
    const thisYearVisitCount = sorted.filter(p => {
      if (!p.date) return false;
      const d = new Date(p.date);
      return !isNaN(d.getTime()) && d.getFullYear() === currentYear;
    }).length;

    // Stats
    const statsEl = document.getElementById("places-stats");
    if (statsEl) {
      statsEl.innerHTML = `
        <div class="stat-pill"><span class="iconify text-sm" data-icon="material-symbols:location-city"></span><span class="font-semibold">${sorted.length}</span><span class="text-neutral-500 dark:text-neutral-400">地点</span></div>
        <div class="stat-pill"><span class="iconify text-sm" data-icon="material-symbols:pin-drop"></span><span class="font-semibold">${totalVisitCount}</span><span class="text-neutral-500 dark:text-neutral-400">到访次数</span></div>
        <div class="stat-pill"><span class="iconify text-sm" data-icon="material-symbols:calendar-today"></span><span class="font-semibold">${thisYearVisitCount}</span><span class="text-neutral-500 dark:text-neutral-400">今年出行</span></div>`;
    }

    // List
    const listEl = document.getElementById("places-list");
    if (listEl) {
      if (sorted.length === 0) {
        listEl.innerHTML = `<div class='w-full p-12 text-center'>
          <span class="iconify text-5xl text-neutral-300 dark:text-neutral-600 mb-4" data-icon="material-symbols:explore"></span>
          <p class='text-neutral-500 dark:text-neutral-400'>暂无地点记录</p>
        </div>`;
      } else {
        const cardsHtml = sorted.map(p => {
          const province = esc(p.province || '未知省份');
          const city = p.city ? ` · ${esc(p.city)}` : '';
          const exp = p.experience ? `<p class='place-exp'>${esc(p.experience)}</p>` : '';
          const visitCount = p.visitCount || 1;
          const dateStr = p.date || '';
          return `<article class='place-card'>
            <div class='flex items-start justify-between gap-4'>
              <div class='flex-1 min-w-0'>
                <h3 class='place-name'>${province}${city}</h3>
                ${exp}
              </div>
              <div class='text-right text-xs text-neutral-400 dark:text-neutral-500 shrink-0'>
                <div class='font-semibold text-neutral-600 dark:text-neutral-300'>到访 ${visitCount} 次</div>
                <div class='mt-0.5'>${esc(dateStr)}</div>
              </div>
            </div>
          </article>`;
        }).join('');
        listEl.innerHTML = `<div class='places-grid'>${cardsHtml}</div>`;
      }
    }

    // Set data for ECharts
    const clientData = sorted.map(p => ({
      province: p.province,
      city: p.city || "",
      district: p.district || "",
      experience: p.experience || "",
      visitCount: p.visitCount || 1,
      date: p.date || "",
    }));
    (window as any).__placesData = clientData;
    window.dispatchEvent(new Event('placesDataReady'));

    // Scan icons
    if ((window as any).Iconify && (window as any).Iconify.scan) {
      ["places-stats", "places-list"].forEach(id => {
        const el = document.getElementById(id);
        if (el) (window as any).Iconify.scan(el);
      });
    }
  }

  fetchJson(PLACES_PATH).then(data => {
    renderPlaces(data);
  }).catch(err => {
    console.error("[Places] Failed to load:", err);
    const listEl = document.getElementById("places-list");
    if (listEl) listEl.innerHTML = '<p style="text-align:center;color:var(--content-meta);">加载失败，请刷新重试</p>';
  });
</script>

<script is:inline>
(function() {
  var container = document.getElementById('life-map');
  if (!container) return;

  var chartInstance = null;

  function loadECharts() {
    return new Promise(function(resolve, reject) {
      if (window.echarts) { resolve(window.echarts); return; }
      var script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js';
      script.onload = function() { resolve(window.echarts); };
      script.onerror = function() { reject(new Error('ECharts load failed')); };
      document.head.appendChild(script);
    });
  }

  function loadChinaMap() {
    return fetch('/china-map.json')
      .then(function(res) { return res.json(); })
      .catch(function() {
        return fetch('https://cdn.jsdelivr.net/npm/echarts@5.4.3/map/json/china.json')
          .then(function(res) { return res.json(); });
      });
  }

  function initMap() {
    var currentContainer = document.getElementById('life-map');
    if (!currentContainer) return;

    if (chartInstance) { chartInstance.dispose(); chartInstance = null; }

    Promise.all([loadECharts(), loadChinaMap()]).then(function(results) {
      var echartsLib = results[0];
      var chinaMapData = results[1];

      currentContainer = document.getElementById('life-map');
      if (!currentContainer || !chinaMapData) {
        if (currentContainer) currentContainer.innerHTML = '<div class="h-full flex items-center justify-center text-neutral-400">地图数据加载失败</div>';
        return;
      }

      echartsLib.registerMap('china', chinaMapData);
      chartInstance = echartsLib.init(currentContainer);

      var clientSortedPlaces = window.__placesData || [];

      var provinceVisitCount = {};
      var maxVisits = 1;
      clientSortedPlaces.forEach(function(place) {
        var province = place.province;
        var count = place.visitCount || 1;
        if (province) {
          provinceVisitCount[province] = (provinceVisitCount[province] || 0) + count;
          if (provinceVisitCount[province] > maxVisits) maxVisits = provinceVisitCount[province];
        }
      });

      var isDark = document.documentElement.classList.contains('dark');
      var bgColor = isDark ? '#0a0a0a' : '#f5f5f5';
      var emptyColor = isDark ? '#2a2a2a' : '#e8e8e8';
      var borderColor = isDark ? '#3f3f46' : '#ccc';

      var provinceData = (chinaMapData.features || []).map(function(f) {
        var name = f.properties && f.properties.name;
        var normalizedName = name.replace(/省|自治区|特别行政区/g, '');
        var visits = provinceVisitCount[normalizedName] || provinceVisitCount[name] || 0;
        var places = clientSortedPlaces.filter(function(p) {
          var pName = (p.province || '').replace(/省|自治区|特别行政区/g, '');
          return pName === normalizedName || pName === name;
        });
        return { name: name, value: visits, places: places };
      });

      var option = {
        backgroundColor: 'transparent',
        tooltip: {
          trigger: 'item',
          formatter: function(params) {
            if (params.value && params.value > 0) {
              var places = params.data && params.data.places ? params.data.places : [];
              var tip = '<strong>' + params.name + '</strong><br/>到访：' + params.value + '次';
              if (places.length > 0) {
                tip += "<br/><span style='font-size:11px;opacity:0.7;'>";
                for (var i = 0; i < Math.min(places.length, 5); i++) {
                  tip += '<br/>• ' + (places[i].city || '未标记') + '(' + (places[i].visitCount || 1) + '次)';
                }
                if (places.length > 5) tip += '<br/>...等' + places.length + '处';
                tip += '</span>';
              }
              return tip;
            }
            return '<strong>' + params.name + '</strong><br/><span style="opacity:0.5;">未到访</span>';
          }
        },
        visualMap: {
          type: 'piecewise',
          show: true,
          left: 20,
          bottom: 20,
          pieces: [
            {gt: Math.ceil(maxVisits * 0.8), color: isDark ? '#555' : '#000'},
            {gt: Math.ceil(maxVisits * 0.5), lte: Math.ceil(maxVisits * 0.8), color: isDark ? '#777' : '#333'},
            {gt: 1, lte: Math.ceil(maxVisits * 0.5), color: isDark ? '#999' : '#666'},
            {value: 0, color: emptyColor}
          ],
          textStyle: {color: isDark ? '#a1a1aa' : '#52525b', fontSize: 12}
        },
        series: [{
          name: '省份',
          type: 'map',
          map: 'china',
          roam: true,
          zoom: 1.2,
          center: [105, 36],
          itemStyle: {
            areaColor: emptyColor,
            borderColor: borderColor,
            borderWidth: 1
          },
          emphasis: {
            itemStyle: { areaColor: isDark ? '#444' : '#ccc' },
            label: {show: true}
          },
          select: {disabled: true},
          data: provinceData
        }]
      };

      chartInstance.setOption(option);
      setTimeout(function() { chartInstance.resize(); }, 100);
    }).catch(function(err) {
      var failContainer = document.getElementById('life-map');
      if (failContainer) failContainer.innerHTML = '<div class="h-full flex items-center justify-center text-neutral-400">加载失败: ' + (err.message || '') + '</div>';
    });
  }

  function tryInitMap() {
    if (window.__placesData) {
      initMap();
    } else {
      // Poll for data from bundled script
      var pollCount = 0;
      var pollInterval = setInterval(function() {
        pollCount++;
        if (window.__placesData || pollCount > 50) {
          clearInterval(pollInterval);
          initMap();
        }
      }, 200);
    }
  }

  function whenReady(fn) {
    if (document.readyState === 'complete') {
      requestAnimationFrame(fn);
    } else {
      window.addEventListener('load', function() { requestAnimationFrame(fn); });
    }
  }

  whenReady(tryInitMap);

  window.addEventListener('resize', function() {
    if (chartInstance) chartInstance.resize();
  });

  // Re-init on theme change
  var observer = new MutationObserver(function(mutations) {
    mutations.forEach(function(m) {
      if (m.attributeName === 'class') {
        if (chartInstance) { chartInstance.dispose(); chartInstance = null; }
        tryInitMap();
      }
    });
  });
  observer.observe(document.documentElement, { attributes: true });

  // Re-init on SPA navigation
  document.addEventListener('astro:after-swap', function() {
    if (document.getElementById('life-map') && !chartInstance) {
      whenReady(tryInitMap);
    }
  });
  document.addEventListener('swup:contentReplaced', function() {
    if (document.getElementById('life-map')) {
      if (chartInstance) { chartInstance.dispose(); chartInstance = null; }
      whenReady(tryInitMap);
    }
  });
})();
</script>

<style>
  .stat-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border: 2px solid #000;
    border-radius: 50px;
    font-size: 13px;
    color: var(--deep-text);
  }
  :root.dark .stat-pill {
    border-color: #3f3f46;
  }

  .stat-pill :global(svg) {
    color: var(--primary);
  }

  .places-grid {
    display: grid;
    gap: 0.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .places-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .place-card {
    padding: 0.875rem 1rem;
    border: 2px solid #000;
    border-radius: var(--radius-large);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  :root.dark .place-card {
    border-color: #3f3f46;
  }
  .place-card:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }
  :root.dark .place-card:hover {
    border-color: #fff;
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.06);
  }

  .place-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--deep-text);
    margin: 0;
  }

  .place-exp {
    margin: 0.25rem 0 0;
    font-size: 0.8125rem;
    color: var(--content-meta);
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .place-card {
      padding: 0.75rem 0.875rem;
    }
  }
</style>
