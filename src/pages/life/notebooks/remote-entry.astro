---
import Comment from "@components/comment/index.astro";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title="云端笔记">
	<div class="diary-detail-page">
		<article class="diary-paper">
			<a id="back-link" href="/life/notebooks/" class="diary-paper-back">
				<span>←</span>
				<span>返回笔记本</span>
			</a>

			<h1 id="entry-title" class="diary-paper-title">加载中...</h1>

			<div id="entry-content" class="diary-paper-content custom-md"></div>

			<div class="diary-paper-footer">
				<div id="entry-tags" class="diary-tags"></div>
				<span id="entry-date" class="diary-date-final"></span>
			</div>
		</article>

		<Comment customPath="/life/notebooks/remote-entry/" />
	</div>
</MainGridLayout>

<style>
	.diary-detail-page { max-width: 48rem; margin: 0 auto; }
	.diary-paper { background: var(--page-bg); color: var(--deep-text); padding: 2rem 0.75rem; }
	@media (min-width: 768px) { .diary-paper { padding: 2rem 1.25rem; } }

	.diary-paper-back {
		display: inline-flex; align-items: center; gap: 0.4rem;
		font-size: 0.85rem; color: var(--content-meta); text-decoration: none;
		margin-bottom: 2rem; transition: color 0.2s;
	}
	.diary-paper-back:hover { color: var(--primary); }

	.diary-paper-title { font-size: 1.75rem; font-weight: 700; color: var(--deep-text); margin: 0 0 2rem; line-height: 1.4; }

	.diary-paper-content { font-size: 1rem; line-height: 1.9; }
	.diary-paper-content :global(p) { margin: 0 0 1.25rem; }
	.diary-paper-content :global(h1) { font-size: 1.5rem; font-weight: 700; margin: 2rem 0 1rem; }
	.diary-paper-content :global(h2) { font-size: 1.25rem; font-weight: 700; margin: 1.75rem 0 0.75rem; }
	.diary-paper-content :global(h3) { font-size: 1.1rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
	.diary-paper-content :global(blockquote) { border-left: 3px solid var(--primary); padding-left: 1em; margin: 0 0 1.25rem; color: var(--content-meta); }
	.diary-paper-content :global(pre) { background: var(--codeblock-bg, #f6f8fa); padding: 0.75em; overflow-x: auto; margin: 0 0 1.25rem; font-size: 0.875rem; }
	.diary-paper-content :global(code) { font-family: 'JetBrains Mono', monospace; font-size: 0.875em; }
	.diary-paper-content :global(pre code) { background: none; padding: 0; }
	.diary-paper-content :global(img) { max-width: 100%; border-radius: 0.5rem; margin: 0.5rem 0; }
	.diary-paper-content :global(a) { color: var(--primary); }
	.diary-paper-content :global(hr) { border: none; border-top: 1px solid var(--line-divider); margin: 2rem 0; }
	.diary-paper-content :global(ul), .diary-paper-content :global(ol) { padding-left: 1.5em; margin: 0 0 1.25rem; }
	.diary-paper-content :global(li) { margin-bottom: 0.25rem; line-height: 1.8; }
	.diary-paper-content :global(table) { width: 100%; border-collapse: collapse; margin: 0 0 1.25rem; }
	.diary-paper-content :global(th), .diary-paper-content :global(td) { border: 1px solid var(--line-divider); padding: 0.4em 0.6em; text-align: left; }
	.diary-paper-content :global(th) { background: var(--hover); font-weight: 600; }

	.diary-paper-footer {
		display: flex; align-items: flex-end; justify-content: space-between;
		margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--line-divider);
	}
	.diary-date-final { font-size: 0.85rem; color: var(--content-meta); text-align: right; font-style: italic; }
	.diary-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
	.diary-tag { padding: 0.25rem 0.75rem; background: var(--btn-regular-bg-hover); border-radius: 9999px; font-size: 0.75rem; color: var(--content-meta); }
</style>

