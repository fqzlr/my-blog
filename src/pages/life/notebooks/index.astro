---
import { Icon } from "astro-icon/components";
import NotebooksEditor from "@/components/edit/NotebooksEditor.svelte";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title="笔记本" description="成长日记、学习复盘、灵感随笔">
	<div class="diary-page flex w-full flex-col gap-6">
		<div class="flex items-center gap-3 mb-2">
			<div class="w-12 h-12 rounded-2xl bg-black dark:bg-white flex items-center justify-center">
				<Icon name="material-symbols:menu-book" class="text-[1.4rem] text-white dark:text-black" />
			</div>
			<div>
				<h1 class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">笔记本</h1>
				<p class="text-sm text-neutral-500 dark:text-neutral-400">成长日记、学习复盘、灵感随笔</p>
			</div>
			<div class="page-header-toolbar-slot flex-shrink-0 ml-auto"></div>
		</div>

		<div data-no-swup>
			<NotebooksEditor client:only />
		</div>

		<!-- 笔记本网格 -->
		<section>
			<div id="notebooks-content">
				<div class="diary-empty">
					<span>加载中...</span>
				</div>
			</div>
		</section>

		<!-- 装饰页脚 -->
		<section class="text-center py-4">
			<p class="text-sm text-[var(--content-meta)] opacity-50">
				✨ 每一页都是成长的足迹
			</p>
		</section>
	</div>
</MainGridLayout>

<script>
	const GH_OWNER = "fqzlr";
	const GH_REPO = "my-blog";
	const NOTEBOOKS_PATH = "public/notebooks.json";

	async function fetchJson(path: string): Promise<any> {
		if (path.startsWith("public/")) {
			try {
				const res = await fetch("/" + path.slice(7));
				if (res.ok) return await res.json();
			} catch {}
		}
		const branch = (typeof window !== 'undefined' && (window as any).__DEPLOY_BRANCH__) || "master";
		const apiPath = `repos/${GH_OWNER}/${GH_REPO}/contents/${path}?ref=${branch}`;
		const res = await fetch("/api/github", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({
				path: apiPath,
				method: "GET",
				headers: { Accept: "application/vnd.github+json" },
			}),
		});
		if (!res.ok) throw new Error("HTTP " + res.status);
		const data = await res.json();
		const text = decodeURIComponent(escape(atob(data.content.replace(/\n/g, ""))));
		return JSON.parse(text);
	}

	function esc(s: string): string {
		const d = document.createElement("div");
		d.textContent = s;
		return d.innerHTML;
	}

	function renderNotebooks(notebooks: any[]) {
		const el = document.getElementById("notebooks-content");
		if (!el) return;

		if (!notebooks || notebooks.length === 0) {
			el.innerHTML = `
				<div class="diary-empty">
					<div class="text-6xl mb-4">📖</div>
					<h3 class="text-xl font-semibold mb-2 text-[var(--text-color)]">还没有日记本</h3>
					<p class="text-sm text-[var(--content-meta)]">开始记录你的第一篇日记吧！</p>
					<div class="mt-6 p-4 rounded-xl bg-[var(--btn-regular-bg)] text-left text-sm">
						<p class="text-[var(--text-color)] mb-2">创建步骤：</p>
						<ol class="text-[var(--content-meta)] space-y-1 list-decimal list-inside">
							<li>在 <code class="px-1 rounded bg-[var(--btn-regular-bg-hover)] font-mono">src/content/life/notebooks/</code> 下创建文件夹</li>
							<li>在文件夹内创建 <code class="px-1 rounded bg-[var(--btn-regular-bg-hover)] font-mono">_index.json</code> 文件</li>
							<li>在文件夹内创建 <code class="px-1 rounded bg-[var(--btn-regular-bg-hover)] font-mono">*.md</code> 文件作为日记条目</li>
						</ol>
					</div>
				</div>`;
			return;
		}

		// Sort by updatedAt desc
		notebooks.sort((a, b) => new Date(b.updatedAt).getTime() - new Date(a.updatedAt).getTime());

		let html = '<div class="diary-grid">';
		for (const book of notebooks) {
			const selfPath = `/life/notebooks/${encodeURIComponent(book.folderName)}/`;
			const coverSrc = book.cover || "";
			const name = esc(book.name || "未命名笔记本");
			const summary = esc(book.summary || "暂无描述");
			const entries = book.entries || 0;
			const updatedAt = book.updatedAt ? book.updatedAt.split("T")[0] : "未更新";

			const coverHtml = coverSrc
				? `<img src="${esc(coverSrc)}" alt="${name}" class="diary-cover-img" loading="lazy" />`
				: `<div class="diary-cover-placeholder"><span class="diary-cover-placeholder-icon">📔</span></div>`;

			html += `
				<a href="${selfPath}" class="diary-notebook group">
					<div class="diary-cover-img-area">
						${coverHtml}
					</div>
					<div class="diary-cover-text">
						<div class="flex items-center gap-2 mb-2">
							<span class="px-2 py-0.5 rounded-full text-xs font-medium diary-cover-tag">笔记</span>
							<span class="text-xs diary-cover-meta">${entries} 篇</span>
						</div>
						<h3 class="text-lg font-bold diary-cover-name">${name}</h3>
						<p class="text-sm diary-cover-desc line-clamp-2 mt-1">${summary}</p>
					</div>
					<div class="diary-notebook-footer">
						<span class="text-xs">${updatedAt}</span>
						<span class="iconify material-symbols--chevron-right-rounded text-base transition-transform group-hover:translate-x-1"></span>
					</div>
				</a>`;
		}
		html += '</div>';
		el.innerHTML = html;

		// Scan for Iconify icons
		if ((window as any).Iconify && (window as any).Iconify.scan) {
			(window as any).Iconify.scan(el);
		}
	}

	const el = document.getElementById("notebooks-content");
	if (el) {
		fetchJson(NOTEBOOKS_PATH)
			.then((data) => renderNotebooks(data))
			.catch((err) => {
				console.error("[Notebooks] Failed to load:", err);
				el.innerHTML = '<div class="diary-empty"><span>加载失败，请刷新重试</span></div>';
			});
	}
</script>

<style>
	.diary-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1.5rem;
	}
	.diary-notebook {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		border-radius: var(--radius-xl);
		overflow: hidden;
		background: var(--card-bg);
		border: 1px solid var(--line-divider);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}
	.diary-notebook:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
	}
	.diary-cover-img-area {
		position: relative;
		aspect-ratio: 2 / 1;
		overflow: hidden;
		background: linear-gradient(135deg, var(--card-bg) 0%, color-mix(in srgb, var(--primary) 8%, var(--card-bg)) 100%);
	}
	.diary-cover-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}
	.diary-notebook:hover .diary-cover-img {
		transform: scale(1.06);
	}
	.diary-cover-placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, var(--card-bg) 0%, color-mix(in srgb, var(--primary) 12%, var(--card-bg)) 100%);
	}
	.diary-cover-placeholder-icon {
		font-size: 3.5rem;
		opacity: 0.35;
		transition: all 0.3s ease;
	}
	.diary-notebook:hover .diary-cover-placeholder-icon {
		opacity: 0.55;
		transform: scale(1.1);
	}
	.diary-cover-text {
		position: relative;
		padding: 1.25rem 1.25rem 0.75rem;
	}
	.diary-cover-tag {
		background: color-mix(in srgb, var(--primary) 20%, transparent);
		color: var(--primary);
	}
	.diary-cover-meta {
		color: var(--content-meta);
	}
	.diary-cover-name {
		color: var(--text-color);
		line-height: 1.3;
	}
	.diary-notebook:hover .diary-cover-name {
		color: var(--primary);
	}
	.diary-cover-desc {
		color: var(--content-meta);
		line-height: 1.5;
	}
	.diary-notebook-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 1.25rem;
		margin-top: auto;
		border-top: 1px solid var(--line-divider);
		color: var(--content-meta);
	}
	.diary-empty {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 4rem 2rem;
		background: var(--card-bg);
		border: 2px dashed var(--line-divider);
		border-radius: var(--radius-3xl);
	}
	.line-clamp-2 {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
