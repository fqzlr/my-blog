---
import CalendarGrid from "@components/pages/calendar/CalendarGrid.svelte";
import EventDetailPanel from "@components/pages/calendar/EventDetailPanel.svelte";
import EventOverview from "@components/pages/calendar/EventOverview.svelte";
import FileCodeEditor from "@/components/edit/FileCodeEditor.svelte";
import PageTitle from "@/components/common/PageTitle.astro";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

if (!siteConfig.pages.calendar) {
	return Astro.redirect("/404/");
}

const title = i18n(I18nKey.calendar);
const description = i18n(I18nKey.calendarDescription);
---

<MainGridLayout title={title} description={description}>
	<div class="calendar-page">
		<div class="calendar-page__shell">
			<header class="calendar-page__header flex justify-between items-start gap-4 flex-wrap">
				<div class="flex-1 min-w-0">
					<PageTitle title={title} eyebrow="Calendar" variant="stacked" />
				</div>
				<div class="page-header-toolbar-slot flex-shrink-0"></div>
			</header>

			<div data-no-swup>
				<FileCodeEditor
					client:only
					filePath="src/config/calendarConfig.ts"
					pageName="日历页面"
				/>
			</div>

			<aside class="calendar-page__rail calendar-page__rail--left" aria-label={i18n(I18nKey.calendarUpcoming)}>
				<EventOverview client:load />
			</aside>

			<main class="calendar-page__main" aria-label={title}>
				<CalendarGrid client:load />
			</main>

			<aside class="calendar-page__rail calendar-page__rail--right" aria-label={i18n(I18nKey.calendarTodayEvents)}>
				<EventDetailPanel client:load />
			</aside>
		</div>
	</div>
</MainGridLayout>

<style>
	@media (max-width: 768px) {
		:has(> .page-header-toolbar-slot) {
			flex-direction: column;
		}
		.page-header-toolbar-slot {
			width: 100%;
		}
	}
</style>
