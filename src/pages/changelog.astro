---
import { Icon } from "astro-icon/components";
import ChangelogEditor from "@/components/edit/ChangelogEditor.svelte";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

if (!siteConfig.pages.changelog) {
	return Astro.redirect("/404/");
}

const displayTitle = i18n(I18nKey.changelogTitle);
const displaySubtitle = i18n(I18nKey.changelogSubtitle);
---

<MainGridLayout title={displayTitle} description={displaySubtitle}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-4 py-6 md:px-9 relative w-full">

      <!-- 头部 -->
      <div class="flex items-center gap-3 mb-4">
        <div class="w-12 h-12 rounded-2xl bg-black dark:bg-white flex items-center justify-center">
          <Icon name="material-symbols:history" class="text-[1.4rem] text-white dark:text-black" />
        </div>
        <div>
          <h1 data-pagefind-meta="title" data-pagefind-weight="10" class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">{displayTitle}</h1>
          <p class="text-sm text-neutral-500 dark:text-neutral-400">{displaySubtitle}</p>
        </div>
      </div>

      <!-- 编辑工具栏 -->
      <div data-no-swup>
        <ChangelogEditor client:only />
      </div>

      <!-- 分类筛选胶囊（JS 动态渲染） -->
      <div class="cl-filter-bar" id="cl-filter-bar">
        <div class="tools-tab-pill" data-cl-tab-nav>
          <div class="tools-tab-indicator" data-cl-tab-indicator></div>
          <button data-cl-tab="all" class="tools-tab-btn tools-tab-btn-active">
            全部
            <span class="tools-tab-badge" id="cl-count-all">-</span>
          </button>
          <button data-cl-tab="feature" class="tools-tab-btn tools-tab-btn-inactive">
            <iconify-icon icon="material-symbols:rocket-launch" class="text-sm"></iconify-icon>
            <span>功能</span>
          </button>
          <button data-cl-tab="improvement" class="tools-tab-btn tools-tab-btn-inactive">
            <iconify-icon icon="material-symbols:build" class="text-sm"></iconify-icon>
            <span>改进</span>
          </button>
          <button data-cl-tab="fix" class="tools-tab-btn tools-tab-btn-inactive">
            <iconify-icon icon="material-symbols:bug-report" class="text-sm"></iconify-icon>
            <span>修复</span>
          </button>
          <button data-cl-tab="removal" class="tools-tab-btn tools-tab-btn-inactive">
            <iconify-icon icon="material-symbols:delete" class="text-sm"></iconify-icon>
            <span>移除</span>
          </button>
        </div>
      </div>

      <!-- 时间线（JS 动态渲染） -->
      <div class="cl-timeline" id="cl-timeline">
        <div class="cl-loading" id="cl-loading">
          <span>加载中...</span>
        </div>
      </div>

    </div>
  </div>
</MainGridLayout>

<script>
  // ========== 更新日志客户端渲染 ==========
  const GH_OWNER = "fqzlr";
  const GH_REPO = "my-blog";
  const CHANGELOG_PATH = "public/changelog.json";

  const typeConfig: Record<string, { label: string; icon: string; cls: string }> = {
    feature: { label: "功能", icon: "material-symbols:rocket-launch", cls: "cl-feature" },
    improvement: { label: "改进", icon: "material-symbols:build", cls: "cl-improvement" },
    fix: { label: "修复", icon: "material-symbols:bug-report", cls: "cl-fix" },
    removal: { label: "移除", icon: "material-symbols:delete", cls: "cl-removal" },
  };

  async function fetchJson(path: string): Promise<any> {
    if (path.startsWith("public/")) {
      try {
        const res = await fetch("/" + path.slice(7));
        if (res.ok) return await res.json();
      } catch {}
    }
    const branch = (typeof window !== 'undefined' && (window as any).__DEPLOY_BRANCH__) || "master";
    const apiPath = `repos/${GH_OWNER}/${GH_REPO}/contents/${path}?ref=${branch}`;
    const res = await fetch("/api/github", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        path: apiPath,
        method: "GET",
        headers: { Accept: "application/vnd.github+json" },
      }),
    });
    if (!res.ok) throw new Error("HTTP " + res.status);
    const data = await res.json();
    const text = decodeURIComponent(escape(atob(data.content.replace(/\n/g, ""))));
    return JSON.parse(text);
  }

  function escapeHtml(str: string): string {
    if (!str) return "";
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function renderTimeline(entries: any[]) {
    const timeline = document.getElementById("cl-timeline");
    const loading = document.getElementById("cl-loading");
    if (!timeline) return;

    if (loading) loading.style.display = "none";

    if (entries.length === 0) {
      timeline.innerHTML = '<div class="cl-empty"><iconify-icon icon="material-symbols:history" class="cl-empty-icon"></iconify-icon><p>暂无更新日志</p></div>';
      return;
    }

    let html = "";
    for (const entry of entries) {
      const t = typeConfig[entry.type] || typeConfig.improvement;
      const dateStr = entry.date ? entry.date.slice(0, 10) : "";
      const timeStr = entry.time ? " · " + escapeHtml(entry.time) : "";
      const contentHtml = entry.contentHtml || "";

      html += `<article class="cl-entry ${t.cls}" data-type="${escapeHtml(entry.type)}" data-slug="${escapeHtml(entry.id)}">`
        + '<div class="cl-entry-dot"></div>'
        + '<div class="cl-entry-body">'
        + '<div class="cl-entry-meta">'
        + `<time datetime="${escapeHtml(entry.date)}">${escapeHtml(dateStr)}${timeStr}</time>`
        + `<span class="cl-entry-version">${escapeHtml(entry.version)}</span>`
        + '</div>'
        + '<div class="cl-entry-card">'
        + `<p class="cl-entry-text">${escapeHtml(entry.description)}</p>`
        + `<div class="cl-entry-content">${contentHtml}</div>`
        + '</div></div></article>';
    }
    timeline.insertAdjacentHTML("beforeend", html);
  }

  function updateCounts(entries: any[]) {
    const countEl = document.getElementById("cl-count-all");
    if (countEl) countEl.textContent = String(entries.length);
  }

  function initTabs() {
    const tabNav = document.querySelector('[data-cl-tab-nav]') as HTMLElement;
    if (!tabNav) return;
    const tabButtons = tabNav.querySelectorAll('[data-cl-tab]') as NodeListOf<HTMLElement>;
    const indicator = tabNav.querySelector('[data-cl-tab-indicator]') as HTMLElement;
    if (!tabButtons.length || !indicator) return;

    function updateIndicator(targetBtn: HTMLElement) {
      indicator.style.left = targetBtn.offsetLeft + 'px';
      indicator.style.top = targetBtn.offsetTop + 'px';
      indicator.style.width = targetBtn.offsetWidth + 'px';
      indicator.style.height = targetBtn.offsetHeight + 'px';
      indicator.style.opacity = '1';
    }

    function activateTab(targetTab: string) {
      tabButtons.forEach((btn) => {
        btn.classList.remove('tools-tab-btn-active');
        btn.classList.add('tools-tab-btn-inactive');
        (btn as HTMLButtonElement).disabled = false;
      });
      const targetBtn = Array.from(tabButtons).find(btn => btn.dataset.clTab === targetTab);
      if (!targetBtn) return;
      targetBtn.classList.remove('tools-tab-btn-inactive');
      targetBtn.classList.add('tools-tab-btn-active');
      (targetBtn as HTMLButtonElement).disabled = true;
      requestAnimationFrame(() => updateIndicator(targetBtn));

      document.querySelectorAll('.cl-entry').forEach((entry) => {
        if (targetTab === 'all' || entry.getAttribute('data-type') === targetTab) {
          entry.classList.remove('hidden');
        } else {
          entry.classList.add('hidden');
        }
      });
    }

    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const tab = button.dataset.clTab;
        if (tab) activateTab(tab);
      });
    });

    const activeBtn = tabNav.querySelector('.tools-tab-btn-active') as HTMLElement;
    if (activeBtn) requestAnimationFrame(() => updateIndicator(activeBtn));

    window.addEventListener('resize', () => {
      const act = tabNav.querySelector('.tools-tab-btn-active') as HTMLElement;
      if (act) updateIndicator(act);
    });
  }

  // 主流程
  fetchJson(CHANGELOG_PATH)
    .then((entries: any[]) => {
      if (!Array.isArray(entries)) entries = [];
      entries.sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());
      renderTimeline(entries);
      updateCounts(entries);
      initTabs();
      // Iconify scan
      if ((window as any).Iconify && (window as any).Iconify.scan) {
        const timeline = document.getElementById("cl-timeline");
        if (timeline) (window as any).Iconify.scan(timeline);
      }
    })
    .catch((err: any) => {
      console.error("[Changelog] Failed to load:", err);
      const timeline = document.getElementById("cl-timeline");
      if (timeline) {
        timeline.innerHTML = '<div class="cl-empty"><iconify-icon icon="material-symbols:error-outline" class="cl-empty-icon"></iconify-icon><p>加载失败，请刷新重试</p></div>';
      }
    });
</script>

<style>
  .cl-loading {
    text-align: center;
    padding: 2rem;
    color: var(--content-meta);
    font-size: 0.875rem;
  }

  .cl-empty {
    text-align: center;
    padding: 4rem 1rem;
  }

  .cl-empty-icon {
    font-size: 3rem;
    color: oklch(0.7 0 0);
    margin-bottom: 1rem;
    display: block;
  }

  .cl-empty p {
    color: var(--content-meta);
    font-size: 0.875rem;
  }

  .cl-filter-bar {
    margin-bottom: 1.5rem;
  }

  .tools-tab-pill {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    padding: 0.375rem;
    border-radius: 1rem;
    border: 2px solid #000;
  }
  :root.dark .tools-tab-pill {
    border-color: #fff;
  }

  .tools-tab-indicator {
    position: absolute;
    border-radius: 9999px;
    background: #000;
    transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                top 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                width 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }
  :root.dark .tools-tab-indicator {
    background: #fff;
  }

  .tools-tab-btn {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    border: none;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    white-space: nowrap;
    cursor: pointer;
    background: transparent;
    transition: color 0.2s;
    flex-shrink: 0;
    font-family: inherit;
  }

  .tools-tab-btn-active {
    color: #fff;
    cursor: default;
  }
  :root.dark .tools-tab-btn-active {
    color: #000;
  }

  .tools-tab-btn-inactive {
    color: #000;
  }
  .tools-tab-btn-inactive:hover {
    opacity: 0.7;
  }
  :root.dark .tools-tab-btn-inactive {
    color: #fff;
  }

  .tools-tab-badge {
    font-size: 0.65rem;
    padding: 0.0625rem 0.375rem;
    border-radius: 9999px;
    background: oklch(0.92 0 0);
    color: oklch(0.35 0 0);
    line-height: 1.4;
  }
  :root.dark .tools-tab-badge {
    background: oklch(0.25 0 0);
    color: oklch(0.65 0 0);
  }

  .tools-tab-btn-active .tools-tab-badge {
    background: rgba(255, 255, 255, 0.25);
    color: #fff;
  }
  :root.dark .tools-tab-btn-active .tools-tab-badge {
    background: rgba(0, 0, 0, 0.2);
    color: #000;
  }

  .cl-timeline {
    position: relative;
    padding-left: 2rem;
  }
  .cl-timeline::before {
    content: "";
    position: absolute;
    left: 6px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: #000;
    opacity: 0.15;
  }
  :root.dark .cl-timeline::before {
    background: #fff;
    opacity: 0.15;
  }

  .cl-entry {
    position: relative;
    margin-bottom: 1.25rem;
    display: flex;
    gap: 1rem;
    animation: clFadeUp 0.4s ease backwards;
  }
  .cl-entry:nth-child(1) { animation-delay: 0.05s; }
  .cl-entry:nth-child(2) { animation-delay: 0.10s; }
  .cl-entry:nth-child(3) { animation-delay: 0.15s; }
  .cl-entry:nth-child(4) { animation-delay: 0.20s; }
  .cl-entry:nth-child(5) { animation-delay: 0.25s; }
  .cl-entry:nth-child(6) { animation-delay: 0.30s; }
  .cl-entry:nth-child(7) { animation-delay: 0.35s; }
  .cl-entry:nth-child(8) { animation-delay: 0.40s; }
  .cl-entry:nth-child(9) { animation-delay: 0.45s; }
  .cl-entry:nth-child(10) { animation-delay: 0.50s; }

  .cl-entry.hidden {
    display: none;
  }

  .cl-entry-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 3px solid var(--line-divider);
    background: var(--page-bg);
    flex-shrink: 0;
    margin-top: 0.35rem;
    margin-left: -1.5rem;
    z-index: 2;
    transition: border-color 0.25s;
  }
  .cl-entry-dot {
    background: #000;
    border-color: #000;
  }
  :root.dark .cl-entry-dot {
    background: #fff;
    border-color: #fff;
  }

  .cl-entry-body {
    flex: 1;
    min-width: 0;
  }

  .cl-entry-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.375rem;
    font-size: 0.75rem;
    color: var(--content-meta);
  }

  .cl-entry-version {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--deep-text);
    background: var(--btn-plain-bg-hover);
    padding: 1px 8px;
    border-radius: 4px;
  }
  :root.dark .cl-entry-version {
    background: oklch(0.20 0 0);
  }

  .cl-entry-card {
    background: var(--card-bg);
    border: 2px solid #000;
    border-radius: var(--radius-large);
    padding: 0.75rem 1rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  :root.dark .cl-entry-card {
    border-color: #3f3f46;
  }

  .cl-entry-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }
  :root.dark .cl-entry-card:hover {
    border-color: #fff;
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.06);
  }

  .cl-entry-text {
    font-size: 0.875rem;
    color: var(--deep-text);
    margin: 0 0 0.75rem 0;
    line-height: 1.6;
    font-weight: 500;
  }

  .cl-entry-content {
    font-size: 0.875rem;
    color: var(--deep-text);
    line-height: 1.7;
  }

  .cl-entry-content :global(h2) {
    font-size: 1rem;
    font-weight: 600;
    margin: 1rem 0 0.5rem 0;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--line-divider);
  }

  .cl-entry-content :global(h3) {
    font-size: 0.9rem;
    font-weight: 600;
    margin: 0.75rem 0 0.4rem 0;
  }

  .cl-entry-content :global(p) {
    margin: 0.5rem 0;
  }

  .cl-entry-content :global(ul),
  .cl-entry-content :global(ol) {
    margin: 0.5rem 0;
    padding-left: 1.25rem;
  }

  .cl-entry-content :global(li) {
    margin: 0.25rem 0;
  }

  .cl-entry-content :global(code) {
    font-size: 0.8em;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    background: var(--btn-plain-bg-hover);
    font-family: var(--font-mono, monospace);
  }

  .cl-entry-content :global(pre) {
    margin: 0.75rem 0;
    padding: 0.75rem;
    border-radius: 8px;
    background: var(--btn-plain-bg-hover);
    overflow-x: auto;
  }

  .cl-entry-content :global(pre code) {
    padding: 0;
    background: transparent;
  }

  .cl-entry-content :global(strong) {
    font-weight: 600;
  }

  .cl-entry-content :global(a) {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @keyframes clFadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 640px) {
    .cl-timeline {
      padding-left: 1.75rem;
    }
    .cl-entry-dot {
      width: 12px;
      height: 12px;
      margin-left: -1.5rem;
    }
    .cl-entry-card {
      padding: 0.625rem 0.875rem;
    }
  }
</style>
