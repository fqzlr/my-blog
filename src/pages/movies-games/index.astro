---
import { Icon } from "astro-icon/components";
import Comment from "@components/comment/index.astro";
import BangumiEditor from "@/components/edit/BangumiEditor.svelte";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

if (!siteConfig.pages.moviesGames) {
	return Astro.redirect("/404/");
}

const title = i18n(I18nKey.moviesGamesTitle);
const description = i18n(I18nKey.moviesGamesSubtitle);
---

<MainGridLayout title={title} description={description}>
	<div class="mg-page-wrapper flex w-full overflow-hidden relative min-h-32">
		<div data-pagefind-body class="card-base z-10 px-6 pt-8 pb-8 relative w-full">
			<header class="mg-header relative w-full mb-8 flex justify-between items-start gap-4 flex-wrap">
				<div class="flex-1 min-w-0">
					<div class="flex items-center gap-3 mb-4">
						<div class="mg-icon flex items-center justify-center w-12 h-12 rounded-2xl bg-[var(--primary)]/10 dark:bg-[var(--primary)]/15 border border-[var(--primary)]/20 shadow-sm">
							<Icon name="material-symbols:movie-outline-rounded" class="text-[1.4rem] text-[var(--primary)]" />
						</div>
						<div>
							<h1 data-pagefind-meta="title" data-pagefind-weight="10">{title}</h1>
						</div>
					</div>
					<p class="text-sm text-[var(--content-meta)] leading-relaxed pl-[3.5rem]">{description}</p>
					<p class="text-xs text-[var(--content-meta)] opacity-60 mt-1.5 pl-[3.5rem]" id="mg-update-time"></p>
				</div>
				<div class="page-header-toolbar-slot flex-shrink-0"></div>
			</header>

			<div data-no-swup>
				<BangumiEditor client:only defaultCategory="all" skipDomCollect={true} customPageName="影视游戏" />
			</div>

			<div class="bangumi-section">
				<div id="mg-content">
					<div class="flex flex-col items-center justify-center py-20 text-center">
						<span>加载中...</span>
					</div>
				</div>
			</div>
		</div>
	</div>
	<Comment customPath="/movies-games/" />
</MainGridLayout>

<script>
	const GH_OWNER = "fqzlr";
	const GH_REPO = "my-blog";

	async function fetchJson(path: string): Promise<any> {
		if (path.startsWith("public/")) {
			try {
				const res = await fetch("/" + path.slice(7));
				if (res.ok) return await res.json();
			} catch {}
		}
		const branch = (typeof window !== 'undefined' && (window as any).__DEPLOY_BRANCH__) || "master";
		const apiPath = `repos/${GH_OWNER}/${GH_REPO}/contents/${path}?ref=${branch}`;
		const res = await fetch("/api/github", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({ path: apiPath, method: "GET", headers: { Accept: "application/vnd.github+json" } }),
		});
		if (!res.ok) throw new Error("HTTP " + res.status);
		const data = await res.json();
		const text = decodeURIComponent(escape(atob(data.content.replace(/\n/g, ""))));
		return JSON.parse(text);
	}

	const statusMap: Record<number, string> = { 1: "wish", 2: "collect", 3: "doing", 4: "on_hold", 5: "dropped" };

	interface MgItem {
		subject_id: number; subject_type: number; rate: number; type: number;
		comment: string | null; tags: string[]; ep_status: number; vol_status: number;
		updated_at: string; private: boolean; link: string;
		subject: {
			id: number; type: number; name: string; name_cn: string;
			short_summary: string;
			images: { medium: string; large: string; common: string; small: string; grid: string };
			volumes: number; eps: number; collection_total: number; score: number; rank: number; tags: any[];
		};
		_subcategory?: string;
	}

	function getItemSubcategory(item: MgItem): string {
		if (item._subcategory) return item._subcategory;
		const tags = item.tags || [];
		if (tags.some((t: string) => t.includes("纪录"))) return "documentary";
		if (tags.some((t: string) => t.includes("动漫") || t.includes("动画"))) return "anime";
		if (tags.some((t: string) => t.includes("电视剧") || t.includes("剧集"))) return "tv";
		return "movie";
	}

	const tabConfig = [
		{ key: "all", label: "全部" },
		{ key: "movie", label: "电影" },
		{ key: "tv", label: "剧集" },
		{ key: "anime", label: "动漫" },
		{ key: "documentary", label: "纪录片" },
		{ key: "game", label: "游戏" },
	];

	function esc(t: string): string {
		const d = document.createElement("div");
		d.textContent = t;
		return d.innerHTML;
	}

	function getStatusText(type: number, subjectType: number): string {
		switch (type) {
			case 1: return subjectType === 4 ? "想玩" : "想看";
			case 2: return subjectType === 4 ? "玩过" : "看过";
			case 3: return subjectType === 4 ? "在玩" : "在看";
			case 4: return "搁置";
			case 5: return "抛弃";
			default: return "未知";
		}
	}

	function getStatusColor(type: number): string {
		switch (type) {
			case 1: return "bg-sky-500/80";
			case 2: return "bg-emerald-500/80";
			case 3: return "bg-amber-500/80";
			case 4: return "bg-violet-500/80";
			case 5: return "bg-rose-400/80";
			default: return "bg-gray-500/80";
		}
	}

	function renderCard(item: MgItem): string {
		const title = item.subject.name_cn || item.subject.name;
		const image = item.subject.images?.medium || "";
		const score = item.rate || 0;
		const scoreText = score > 0 ? `${score}`.replace(/\.0$/, "") : "";
		const displayTags = (item.tags || []).slice(0, 3);

		const imgHtml = image
			? `<img src="${esc(image)}" alt="${esc(title)}" class="mg-img" loading="lazy" />`
			: `<div class="mg-img" style="background:var(--btn-regular-bg);display:flex;align-items:center;justify-content:center;font-size:2rem;">🎬</div>`;

		const scoreHtml = score > 0
			? `<span class="mg-score"><svg class="mg-star" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>${scoreText}</span>`
			: "";

		const tagsHtml = displayTags.length > 0
			? `<div class="mg-tags">${displayTags.map((t: string) => `<span class="mg-tag">${esc(t)}</span>`).join("")}</div>`
			: "";

		const commentHtml = item.comment
			? `<div class="mg-overlay"><p class="mg-comment">${esc(item.comment)}</p></div>`
			: "";

		return `<a href="${esc(item.link)}" class="mg-card group">
			<div class="mg-cover">
				${imgHtml}
				<div class="mg-gradient"></div>
				<span class="mg-status ${getStatusColor(item.type)}">${esc(getStatusText(item.type, item.subject_type))}</span>
				${scoreHtml}
				<div class="mg-info">
					<h3 class="mg-title">${esc(title)}</h3>
					${tagsHtml}
				</div>
				${commentHtml}
			</div>
		</a>`;
	}

	function renderPagination(sectionKey: string, totalItems: number): string {
		const ITEMS_PER_PAGE = 12;
		const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE);
		if (totalPages <= 1) return "";

		const prevDisabled = "disabled";
		const nextDisabled = totalPages === 1 ? "disabled" : "";

		let pageNumsHtml = `<button type="button" class="rounded-lg overflow-hidden w-11 h-11 flex items-center justify-center font-bold bg-(--primary) text-white dark:text-black/70" data-page="1" data-section="${sectionKey}" aria-current="page">1</button>`;
		for (let i = 2; i <= Math.min(totalPages, 7); i++) {
			pageNumsHtml += `<button type="button" class="rounded-lg overflow-hidden w-11 h-11 flex items-center justify-center font-bold btn-card active:scale-[0.85]" data-page="${i}" data-section="${sectionKey}">${i}</button>`;
		}
		if (totalPages > 7) {
			pageNumsHtml += `<span class="mx-1">...</span>`;
			pageNumsHtml += `<button type="button" class="rounded-lg overflow-hidden w-11 h-11 flex items-center justify-center font-bold btn-card active:scale-[0.85]" data-page="${totalPages}" data-section="${sectionKey}">${totalPages}</button>`;
		}

		return `<div class="responsive-pagination flex justify-center items-center mt-8" data-pagination-section="${sectionKey}">
			<div class="mobile-pagination items-center gap-3">
				<button type="button" class="btn-card overflow-hidden rounded-lg text-(--primary) w-11 h-11 disabled:opacity-50 disabled:cursor-not-allowed" data-page="prev" data-section="${sectionKey}" ${prevDisabled}>
					<span class="iconify material-symbols--chevron-left-rounded text-[1.75rem]"></span>
				</button>
				<div class="bg-(--card-bg) flex items-center rounded-lg px-4 h-11 gap-1.5">
					<span class="mobile-current-page text-base font-bold text-(--primary)">1</span>
					<span class="text-sm text-neutral-500 dark:text-neutral-500">/</span>
					<span class="mobile-total-pages text-base font-bold text-neutral-700 dark:text-neutral-300">${totalPages}</span>
				</div>
				<button type="button" class="btn-card overflow-hidden rounded-lg text-(--primary) w-11 h-11 disabled:opacity-50 disabled:cursor-not-allowed" data-page="next" data-section="${sectionKey}" ${nextDisabled}>
					<span class="iconify material-symbols--chevron-right-rounded text-[1.75rem]"></span>
				</button>
			</div>
			<div class="desktop-pagination items-center gap-3">
				<button type="button" class="btn-card overflow-hidden rounded-lg text-(--primary) w-11 h-11 disabled:opacity-50 disabled:cursor-not-allowed" data-page="prev" data-section="${sectionKey}" ${prevDisabled}>
					<span class="iconify material-symbols--chevron-left-rounded text-[1.75rem]"></span>
				</button>
				<div class="bg-(--card-bg) flex flex-row rounded-lg items-center text-neutral-700 dark:text-neutral-300 font-bold" data-page-numbers="${sectionKey}">${pageNumsHtml}</div>
				<button type="button" class="btn-card overflow-hidden rounded-lg text-(--primary) w-11 h-11 disabled:opacity-50 disabled:cursor-not-allowed" data-page="next" data-section="${sectionKey}" ${nextDisabled}>
					<span class="iconify material-symbols--chevron-right-rounded text-[1.75rem]"></span>
				</button>
			</div>
		</div>`;
	}

	function renderMg(rawItems: any[]) {
		const container = document.getElementById("mg-content");
		if (!container) return;

		const mgItems: MgItem[] = rawItems
			.filter((item: any) => ["anime", "game", "real"].includes(item.category))
			.map((item: any) => {
				const imageSrc = typeof item.image === "string" ? item.image : (item.image?.src || "");
				const subjectTypeMap: Record<string, number> = { anime: 2, game: 4, real: 6 };
				return {
					subject_id: 0,
					subject_type: subjectTypeMap[item.category] || 2,
					rate: item.score || 0,
					type: item.status,
					comment: item.comment || null,
					tags: item.tags || [],
					ep_status: 0, vol_status: 0,
					updated_at: item.updated_at || new Date().toISOString(),
					private: false,
					link: item.link || "#",
					_subcategory: item.subcategory,
					subject: {
						id: 0, type: subjectTypeMap[item.category] || 2,
						name: item.title, name_cn: item.name_cn || item.title,
						short_summary: "",
						images: { medium: imageSrc, large: imageSrc, common: imageSrc, small: imageSrc, grid: imageSrc },
						volumes: 0, eps: 0, collection_total: 0,
						score: item.score || 0, rank: 0, tags: [],
					},
				};
			})
			.sort((a: MgItem, b: MgItem) => new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime());

		if (mgItems.length === 0) {
			container.innerHTML = `<div class="flex flex-col items-center justify-center py-20 text-center">
				<div class="inline-flex items-center justify-center w-14 h-14 bg-[var(--btn-regular-bg)] rounded-2xl mb-4 border border-[var(--line-divider)]">
					<span class="iconify material-symbols--movie-outline w-7 h-7 text-[var(--content-meta)]"></span>
				</div>
				<h3 class="text-base font-medium text-[var(--deep-text)] dark:text-[var(--title-active)] mb-1.5">暂无数据</h3>
			</div>`;
			return;
		}

		// Build sections
		const sections: { tabKey: string; tabName: string; items: MgItem[]; filters: { value: string; label: string; count: number }[] }[] = [];
		for (const tc of tabConfig) {
			const items = tc.key === "all" ? mgItems : mgItems.filter((item) => {
				if (tc.key === "game") return item.subject_type === 4;
				if (item.subject_type === 4) return false;
				return getItemSubcategory(item) === tc.key;
			});

			const statusCounts: Record<string, number> = {};
			for (const item of items) {
				const s = statusMap[item.type] || "unknown";
				statusCounts[s] = (statusCounts[s] || 0) + 1;
			}

			const filters = [
				{ value: "all", label: "全部", count: items.length },
				{ value: "collect", label: "看过", count: statusCounts.collect || 0 },
				{ value: "doing", label: "在看", count: statusCounts.doing || 0 },
				{ value: "wish", label: "想看", count: statusCounts.wish || 0 },
				{ value: "on_hold", label: "搁置", count: statusCounts.on_hold || 0 },
				{ value: "dropped", label: "抛弃", count: statusCounts.dropped || 0 },
			];

			sections.push({ tabKey: tc.key, tabName: tc.label, items, filters });
		}

		// Render tabs
		const activeTab = sections[0]?.tabKey || "all";
		let tabsHtml = `<div class="mg-tabs-wrapper mb-6">
			<nav class="tools-tab-pill" data-mg-tab-nav aria-label="Tabs">
				<div class="tools-tab-indicator" data-mg-tab-indicator></div>
				${sections.map(sec => `<button class="tools-tab-btn ${sec.tabKey === activeTab ? "tools-tab-btn-active" : "tools-tab-btn-inactive"}" data-tab="${sec.tabKey}" type="button" ${sec.tabKey === activeTab ? "disabled" : ""}>
					<span>${sec.tabName}</span><span class="tools-tab-badge">${sec.tabCount || sec.items.length}</span>
				</button>`).join("")}
			</nav>
		</div>`;

		// Render sections
		let sectionsHtml = sections.map(sec => {
			if (sec.items.length === 0) {
				return `<div class="mg-section ${sec.tabKey !== activeTab ? "hidden" : ""}" data-section="${sec.tabKey}">
					<div class="flex flex-col items-center justify-center py-16 text-center">
						<p class="text-sm text-[var(--content-meta)]">暂无数据</p>
					</div>
				</div>`;
			}

			const filtersHtml = `<div class="mg-filter-wrapper tools-tab-pill mb-5" data-mg-filter-nav="${sec.tabKey}">
				<div class="tools-tab-indicator" data-mg-filter-indicator="${sec.tabKey}"></div>
				${sec.filters.map(f => `<button class="tools-tab-btn mg-filter-btn ${f.value === "all" ? "tools-tab-btn-active" : "tools-tab-btn-inactive"}" data-filter="${f.value}" data-section="${sec.tabKey}" type="button" ${f.value === "all" ? "disabled" : ""}>
					<span>${f.label}</span><span class="tools-tab-badge">${f.count}</span>
				</button>`).join("")}
			</div>`;

			const gridHtml = `<div class="mg-grid grid grid-cols-3 sm:grid-cols-4 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 md:gap-5">
				${sec.items.map(item => `<div class="mg-item" data-item-section="${sec.tabKey}" data-item-status="${statusMap[item.type] || "unknown"}" data-ext-date="${item.updated_at}">
					${renderCard(item)}
				</div>`).join("")}
			</div>`;

			return `<div class="mg-section ${sec.tabKey !== activeTab ? "hidden" : ""}" data-section="${sec.tabKey}">
				${filtersHtml}${gridHtml}${renderPagination(sec.tabKey, sec.items.length)}
			</div>`;
		}).join("");

		container.innerHTML = tabsHtml + sectionsHtml;

		// Update time
		const timeEl = document.getElementById("mg-update-time");
		if (timeEl) {
			const now = new Date();
			timeEl.textContent = `最后更新于 ${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}-${String(now.getDate()).padStart(2, "0")} ${String(now.getHours()).padStart(2, "0")}:${String(now.getMinutes()).padStart(2, "0")}`;
		}

		// Iconify scan
		if ((window as any).Iconify?.scan) {
			(window as any).Iconify.scan(container);
		}

		initInteractions();
	}

	function initInteractions() {
		function updateIndicator(indicator: HTMLElement, btn: HTMLElement) {
			if (!indicator || !btn) return;
			indicator.style.left = btn.offsetLeft + "px";
			indicator.style.top = btn.offsetTop + "px";
			indicator.style.width = btn.offsetWidth + "px";
			indicator.style.height = btn.offsetHeight + "px";
			indicator.style.opacity = "1";
		}

		function activateBtn(btns: Element[], target: Element, indicator: HTMLElement | null) {
			btns.forEach(btn => {
				btn.classList.remove("tools-tab-btn-active");
				btn.classList.add("tools-tab-btn-inactive");
				btn.removeAttribute("disabled");
			});
			target.classList.remove("tools-tab-btn-inactive");
			target.classList.add("tools-tab-btn-active");
			target.setAttribute("disabled", "true");
			if (indicator) requestAnimationFrame(() => updateIndicator(indicator, target as HTMLElement));
		}

		function initIndicators() {
			const tabNav = document.querySelector("[data-mg-tab-nav]");
			const tabIndicator = document.querySelector("[data-mg-tab-indicator]");
			if (tabNav && tabIndicator) {
				const activeTab = tabNav.querySelector(".tools-tab-btn-active");
				if (activeTab) requestAnimationFrame(() => updateIndicator(tabIndicator as HTMLElement, activeTab as HTMLElement));
			}
			document.querySelectorAll("[data-mg-filter-indicator]").forEach(indicator => {
				const section = indicator.getAttribute("data-mg-filter-indicator");
				const nav = document.querySelector(`[data-mg-filter-nav="${section}"]`);
				if (nav) {
					const activeFilter = nav.querySelector(".tools-tab-btn-active");
					if (activeFilter) requestAnimationFrame(() => updateIndicator(indicator as HTMLElement, activeFilter as HTMLElement));
				}
			});
		}

		initIndicators();
		window.addEventListener("resize", initIndicators);

		// Click delegation
		document.addEventListener("click", function handleClick(e) {
			// Tab click
			const tab = (e.target as Element).closest("[data-tab]");
			if (tab) {
				const targetTab = (tab as HTMLElement).dataset.tab;
				const tabNav = tab.closest("[data-mg-tab-nav]");
				const tabIndicator = tabNav?.querySelector("[data-mg-tab-indicator]") as HTMLElement | null;
				activateBtn(Array.from(tabNav!.querySelectorAll("[data-tab]")), tab, tabIndicator);
				document.querySelectorAll("[data-section]").forEach(section => {
					section.classList.toggle("hidden", (section as HTMLElement).dataset.section !== targetTab);
				});
				const newFilterIndicator = document.querySelector(`[data-mg-filter-indicator="${targetTab}"]`) as HTMLElement | null;
				const newFilterNav = document.querySelector(`[data-mg-filter-nav="${targetTab}"]`);
				if (newFilterIndicator && newFilterNav) {
					const activeFilter = newFilterNav.querySelector(".tools-tab-btn-active") as HTMLElement | null;
					if (activeFilter) {
						newFilterIndicator.style.opacity = "0";
						requestAnimationFrame(() => updateIndicator(newFilterIndicator, activeFilter));
					}
				}
				return;
			}

			// Filter click
			const filterBtn = (e.target as Element).closest(".mg-filter-btn");
			if (filterBtn) {
				const filter = (filterBtn as HTMLElement).dataset.filter;
				const sid = (filterBtn as HTMLElement).dataset.section;
				const filterNav = filterBtn.closest("[data-mg-filter-nav]");
				const filterIndicator = filterNav?.querySelector("[data-mg-filter-indicator]") as HTMLElement | null;
				activateBtn(Array.from(filterNav!.querySelectorAll(".mg-filter-btn")), filterBtn, filterIndicator);
				document.querySelectorAll(`[data-item-section="${sid}"]`).forEach(item => {
					const match = filter === "all" || (item as HTMLElement).dataset.itemStatus === filter;
					item.classList.toggle("hidden", !match);
					(item as HTMLElement).style.display = match ? "block" : "none";
				});
				const pagination = document.querySelector(`[data-pagination-section="${sid}"]`);
				if (pagination) {
					const visibleItems = document.querySelectorAll(`[data-item-section="${sid}"]:not(.hidden)`);
					pagination.dispatchEvent(new CustomEvent("updatePagination", { detail: { visibleCount: visibleItems.length } }));
				}
			}

			// Pagination click
			const pageBtn = (e.target as Element).closest("[data-page]");
			if (pageBtn && pageBtn.tagName === "BUTTON") {
				const page = (pageBtn as HTMLElement).dataset.page;
				const sid = (pageBtn as HTMLElement).dataset.section;
				if (!page || !sid) return;
				handlePaginationClick(sid, page);
			}
		});
	}

	function handlePaginationClick(sectionId: string, page: string) {
		const ITEMS_PER_PAGE = 12;
		const pagination = document.querySelector(`[data-pagination-section="${sectionId}"]`);
		if (!pagination) return;

		const items = Array.from(document.querySelectorAll(`[data-item-section="${sectionId}"]:not(.hidden)`)) as HTMLElement[];
		const totalPages = Math.ceil(items.length / ITEMS_PER_PAGE);

		let currentPage: number;
		const currentActive = pagination.querySelector("[data-page-numbers] [aria-current='page']");
		const currentNum = currentActive ? parseInt(currentActive.textContent || "1") : 1;

		if (page === "prev") currentPage = Math.max(1, currentNum - 1);
		else if (page === "next") currentPage = Math.min(totalPages, currentNum + 1);
		else currentPage = parseInt(page);

		// Hide all, show current page
		items.forEach(item => item.style.display = "none");
		const start = (currentPage - 1) * ITEMS_PER_PAGE;
		const end = start + ITEMS_PER_PAGE;
		items.slice(start, end).forEach(item => item.style.display = "block");

		// Update buttons
		pagination.querySelectorAll("[data-page='prev']").forEach(btn => { (btn as HTMLButtonElement).disabled = currentPage === 1; });
		pagination.querySelectorAll("[data-page='next']").forEach(btn => { (btn as HTMLButtonElement).disabled = currentPage === totalPages; });

		// Update page numbers
		const pageNumsContainer = pagination.querySelector(`[data-page-numbers="${sectionId}"]`);
		if (pageNumsContainer) {
			const pageNumbers: (number | string)[] = [];
			if (totalPages <= 7) {
				for (let i = 1; i <= totalPages; i++) pageNumbers.push(i);
			} else {
				pageNumbers.push(1);
				const left = Math.max(2, currentPage - 2);
				const right = Math.min(totalPages - 1, currentPage + 2);
				if (left > 2) pageNumbers.push("...");
				for (let i = left; i <= right; i++) pageNumbers.push(i);
				if (right < totalPages - 1) pageNumbers.push("...");
				if (totalPages > 1) pageNumbers.push(totalPages);
			}

			let html = "";
			for (const p of pageNumbers) {
				if (p === "...") {
					html += `<span class="mx-1">...</span>`;
				} else {
					const isActive = p === currentPage;
					html += `<button type="button" class="rounded-lg overflow-hidden w-11 h-11 flex items-center justify-center font-bold ${isActive ? "bg-(--primary) text-white dark:text-black/70" : "btn-card active:scale-[0.85]"}" data-page="${p}" data-section="${sectionId}" ${isActive ? "aria-current='page'" : ""}>${p}</button>`;
				}
			}
			pageNumsContainer.innerHTML = html;
		}

		// Update mobile display
		const mobileCurrentPage = pagination.querySelector(".mobile-current-page");
		if (mobileCurrentPage) mobileCurrentPage.textContent = currentPage.toString();
	}

	async function init() {
		try {
			const rawItems = await fetchJson("public/bangumi.json");
			renderMg(rawItems);
		} catch (e) {
			console.error("[影视游戏] 加载失败:", e);
			const container = document.getElementById("mg-content");
			if (container) {
				container.innerHTML = `<div class="flex flex-col items-center justify-center py-20 text-center">
					<div class="inline-flex items-center justify-center w-14 h-14 bg-[var(--btn-regular-bg)] rounded-2xl mb-4 border border-[var(--line-divider)]">
						<span class="iconify material-symbols--movie-outline w-7 h-7 text-[var(--content-meta)]"></span>
					</div>
					<h3 class="text-base font-medium text-[var(--deep-text)] dark:text-[var(--title-active)] mb-1.5">暂无数据</h3>
				</div>`;
			}
		}
	}

	init();
</script>

