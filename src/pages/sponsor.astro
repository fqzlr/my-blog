---
import Icon from "@components/common/Icon.astro";
import PageTitle from "@/components/common/PageTitle.astro";
import SponsorEditor from "@/components/edit/SponsorEditor.svelte";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

if (!siteConfig.pages.sponsor) {
	return Astro.redirect("/404/");
}

const title = i18n(I18nKey.sponsorTitle);
const description = i18n(I18nKey.sponsorDescription);
---

<MainGridLayout title={title} description={description}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 页面标题和描述 -->
      <div class="mb-8 flex justify-between items-start gap-4 flex-wrap">
        <div class="flex-1 min-w-0">
          <PageTitle title={title} eyebrow="Sponsor" variant="stacked" />
          <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4 mt-3" id="sponsor-description">
            加载中...
          </p>
          <div id="sponsor-usage"></div>
        </div>
        <div class="page-header-toolbar-slot flex-shrink-0"></div>
      </div>

      <div data-no-swup>
        <SponsorEditor client:only />
      </div>

      <!-- 赞助方式 -->
      <div id="sponsor-methods"></div>
    </div>
  </div>

  <!-- 赞助者列表 -->
  <div id="sponsor-list-wrapper"></div>

  <!-- 样式已迁移至 src/styles/pages/sponsor.css -->

  <script>
    const GH_OWNER = "fqzlr";
    const GH_REPO = "my-blog";
    const SPONSOR_PATH = "public/sponsor.json";

    async function fetchJson(path: string): Promise<any> {
      if (path.startsWith("public/")) {
        try {
          const res = await fetch("/" + path.slice(7));
          if (res.ok) return await res.json();
        } catch {}
      }
      const branch = (typeof window !== 'undefined' && (window as any).__DEPLOY_BRANCH__) || "master";
      const apiPath = `repos/${GH_OWNER}/${GH_REPO}/contents/${path}?ref=${branch}`;
      const res = await fetch("/api/github", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ path: apiPath, method: "GET", headers: { Accept: "application/vnd.github+json" } }),
      });
      if (!res.ok) throw new Error("HTTP " + res.status);
      const data = await res.json();
      const text = decodeURIComponent(escape(atob(data.content.replace(/\n/g, ""))));
      return JSON.parse(text);
    }

    function esc(s: string) { const d = document.createElement("div"); d.textContent = s; return d.innerHTML; }

    function renderSponsor(data: any) {
      // Description
      const descEl = document.getElementById("sponsor-description");
      if (descEl && data.description) descEl.textContent = data.description;

      // Usage
      const usageEl = document.getElementById("sponsor-usage");
      if (usageEl && data.usage) {
        usageEl.innerHTML = `<div class="mb-8 p-4 rounded-lg bg-(--primary)/8 dark:bg-(--btn-regular-bg) border border-(--primary)/30 dark:border-none backdrop-blur-xs shadow-xs usage-info-box">
          <div class="flex items-start gap-2">
            <span class="iconify text-(--primary) text-lg shrink-0 mt-0.5" data-icon="material-symbols:info-outline"></span>
            <p class="text-sm text-neutral-700 dark:text-neutral-200 leading-relaxed">${esc(data.usage)}</p>
          </div></div>`;
      }

      // Methods
      const methodsEl = document.getElementById("sponsor-methods");
      const methods = (data.methods || []).filter((m: any) => m.enabled);
      if (methodsEl && methods.length > 0) {
        const tabsHtml = methods.map((m: any, i: number) =>
          `<button class="sponsor-qr-card__tab-btn ${i === 0 ? 'sponsor-qr-card__tab-btn--active' : 'sponsor-qr-card__tab-btn--inactive'}" data-sponsor-tab="${i}" type="button">
            ${m.icon ? `<span class="iconify text-[1rem]" data-icon="${esc(m.icon)}"></span>` : ''}
            ${esc(m.name)}</button>`
        ).join('');

        const panelsHtml = methods.map((m: any, i: number) => {
          let content: string;
          if (m.name === "爱发电" && m.link) {
            content = `<div class="afd-card">
              <div class="afd-card-logo-row">
                ${m.icon ? `<span class="iconify afd-card-icon" data-icon="${esc(m.icon)}"></span>` : ''}
                <h3 class="afd-card-title">爱发电</h3>
              </div>
              <p class="afd-card-subtext">通过 爱发电 进行打赏</p>
              <a href="${esc(m.link)}" target="_blank" rel="noopener noreferrer" class="afd-btn">
                前往打赏 <span class="iconify" data-icon="fa7-solid:arrow-up-right-from-square"></span>
              </a></div>`;
          } else if (m.qrCode) {
            const imgSrc = m.qrCode.startsWith('/') ? m.qrCode : '/' + m.qrCode;
            content = `<div class="sponsor-qr-card__image-wrapper">
              <img src="${esc(imgSrc)}" alt="${esc(m.name)} 扫码赞助" class="sponsor-qr-card__image" loading="lazy" />
            </div>`;
          } else {
            content = `<div class="sponsor-qr-card__empty">
              <span class="iconify text-[3rem] mb-2 opacity-40" data-icon="material-symbols:qr-code-scanner"></span>
              <span class="sponsor-qr-card__empty-text">暂不开通</span>
            </div>`;
          }
          return `<div class="sponsor-qr-card__panel ${i !== 0 ? 'hidden' : ''}" data-sponsor-panel="${i}">${content}</div>`;
        }).join('');

        methodsEl.innerHTML = `<div class="sponsor-qr-card__outer"><div class="sponsor-qr-card">
          <div class="sponsor-qr-card__header"><h3 class="sponsor-qr-card__title">扫码赞助</h3></div>
          <p class="sponsor-qr-card__subtitle">选择你喜欢的支付方式</p>
          <div class="sponsor-qr-card__tabs-wrapper"><div class="sponsor-qr-card__tabs-pill" data-sponsor-tab-nav>
            <div class="sponsor-qr-card__tabs-indicator" data-sponsor-tab-indicator></div>
            ${tabsHtml}
          </div></div>
          <div class="sponsor-qr-card__content">${panelsHtml}</div>
        </div></div>`;
      }

      // Sponsors list
      const listWrapper = document.getElementById("sponsor-list-wrapper");
      if (listWrapper && data.showSponsorsList !== false) {
        const sponsors = data.sponsors || [];
        if (sponsors.length > 0) {
          const rowsHtml = sponsors.map((s: any) => `<div class="sponsor-row group">
            <div class="sponsor-avatar">
              ${s.avatar ? `<img src="${esc(s.avatar)}" alt="${esc(s.name)}" class="sponsor-avatar__img" loading="lazy" />` : `<span>${esc(s.name.charAt(0))}</span>`}
            </div>
            <div class="sponsor-info">
              <span class="sponsor-name">${esc(s.name)}</span>
              ${s.date ? `<span class="sponsor-date">${new Date(s.date).toLocaleDateString()}</span>` : ''}
            </div>
            ${s.amount ? `<span class="sponsor-amount">${esc(s.amount)}</span>` : ''}
          </div>`).join('');

          listWrapper.innerHTML = `<div class="flex w-full rounded-(--radius-large) overflow-hidden relative mt-4">
            <div class="card-base z-10 px-9 py-6 relative w-full">
              <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-3"><h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">赞助名单</h2></div>
              </div>
              <div class="sponsor-list">${rowsHtml}</div>
            </div></div>`;
        } else {
          listWrapper.innerHTML = `<div class="flex w-full rounded-(--radius-large) overflow-hidden relative mt-4">
            <div class="card-base z-10 px-9 py-6 relative w-full">
              <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-3"><h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">赞助名单</h2></div>
              </div>
              <div class="text-center py-12 text-neutral-500 dark:text-neutral-500"><p>暂无赞助记录</p></div>
            </div></div>`;
        }
      }

      // Scan icons
      if ((window as any).Iconify && (window as any).Iconify.scan) {
        ["sponsor-usage", "sponsor-methods", "sponsor-list-wrapper"].forEach(id => {
          const el = document.getElementById(id);
          if (el) (window as any).Iconify.scan(el);
        });
      }
    }

    // Tab interaction
    function initSponsorTabs() {
      function updateSponsorIndicator(nav: HTMLElement) {
        const indicator = nav.querySelector("[data-sponsor-tab-indicator]") as HTMLElement;
        const activeBtn = nav.querySelector(".sponsor-qr-card__tab-btn--active") as HTMLElement;
        if (!indicator || !activeBtn) return;
        const navRect = nav.getBoundingClientRect();
        const btnRect = activeBtn.getBoundingClientRect();
        indicator.style.left = (btnRect.left - navRect.left) + "px";
        indicator.style.top = (btnRect.top - navRect.top) + "px";
        indicator.style.width = btnRect.width + "px";
        indicator.style.height = btnRect.height + "px";
        indicator.style.opacity = "1";
      }

      function activateSponsorTab(tabIndex: string) {
        document.querySelectorAll("[data-sponsor-tab]").forEach(btn => {
          const el = btn as HTMLElement;
          if (el.dataset.sponsorTab === tabIndex) {
            el.classList.remove("sponsor-qr-card__tab-btn--inactive");
            el.classList.add("sponsor-qr-card__tab-btn--active");
          } else {
            el.classList.remove("sponsor-qr-card__tab-btn--active");
            el.classList.add("sponsor-qr-card__tab-btn--inactive");
          }
        });
        document.querySelectorAll("[data-sponsor-panel]").forEach(panel => {
          const el = panel as HTMLElement;
          el.classList.toggle("hidden", el.dataset.sponsorPanel !== tabIndex);
        });
        const nav = document.querySelector("[data-sponsor-tab-nav]") as HTMLElement;
        if (nav) updateSponsorIndicator(nav);
      }

      document.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest("[data-sponsor-tab]") as HTMLElement;
        if (!btn) return;
        activateSponsorTab(btn.dataset.sponsorTab || "0");
      });

      window.addEventListener("resize", () => {
        const nav = document.querySelector("[data-sponsor-tab-nav]") as HTMLElement;
        if (nav) updateSponsorIndicator(nav);
      });

      requestAnimationFrame(() => {
        const nav = document.querySelector("[data-sponsor-tab-nav]") as HTMLElement;
        if (nav) updateSponsorIndicator(nav);
      });
    }

    fetchJson(SPONSOR_PATH).then(data => {
      renderSponsor(data);
      initSponsorTabs();
    }).catch(err => {
      console.error("[Sponsor] Failed to load:", err);
      const descEl = document.getElementById("sponsor-description");
      if (descEl) descEl.textContent = "加载失败，请刷新重试";
    });
  </script>

  <style>
    @media (max-width: 768px) {
      :has(> .page-header-toolbar-slot) {
        flex-direction: column;
      }
      .page-header-toolbar-slot {
        width: 100%;
      }
    }
  </style>
</MainGridLayout>
