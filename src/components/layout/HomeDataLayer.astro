---
import DataMetricCard from "@components/features/DataMetricCard.astro";
import LogoLoop from "@components/features/LogoLoop.svelte";
import { profileConfig, skillsConfig } from "@/config";
import {
	getCategoryList,
	getSortedPosts,
	getTagList,
} from "@/utils/content-utils";
import {
	countReadableCharacters,
	normalizeSkillItems,
} from "@/utils/home-data-layer.js";

type DataPill = {
	label: string;
	value: string | number;
	tone?: "dark" | "light" | "outline" | "solid";
};

const posts = await getSortedPosts();
const categories = await getCategoryList();
const tags = await getTagList();
const totalWords = posts.reduce((sum, post) => {
	return sum + countReadableCharacters(post.body || "");
}, 0);

const articlePills: DataPill[] = [
	{ label: "文章", value: posts.length, tone: "light" },
	{ label: "分类", value: categories.length, tone: "solid" },
	{ label: "标签", value: tags.length, tone: "solid" },
	{ label: "字数", value: totalWords.toLocaleString(), tone: "light" },
];

const visitPills: DataPill[] = [
	{ label: "UV", value: "--", tone: "light" },
	{ label: "PV", value: "--", tone: "dark" },
	{ label: "SOURCE", value: "Umami", tone: "outline" },
];

const socialItems = profileConfig.links.map((link) => ({
	name: link.name,
	icon: link.icon,
	href: link.url,
	ariaLabel: link.name,
}));

const skillItems = normalizeSkillItems({ items: skillsConfig.items });
---

<section class="home-data-layer" aria-labelledby="home-data-layer-title" id="home-data-layer">
	<div class="home-data-layer__inner">
		<div class="home-data-layer__heading">
			<p class="home-data-layer__kicker">CONTEXT</p>
			<h2 class="home-data-layer__title-main" id="home-data-layer-title">站点数据</h2>
			<h2 class="home-data-layer__title-matrix">能力矩阵</h2>
		</div>

		<div class="home-data-layer__grid">
			<div class="home-data-layer__row home-data-layer__row--top">
				<DataMetricCard
					title="站点访问"
					eyebrow="VISITS"
					detail="访客与浏览统计载入中"
					icon="material-symbols:visibility-outline-rounded"
					hoverTitle="访问轨迹"
					hoverCode="01"
					variant="square"
					pills={visitPills}
					statKind="visits"
					visualImage="/assets/images/home/home-data-1.webp"
				/>
				<DataMetricCard
					title="文章档案"
					eyebrow="ARCHIVE"
					detail={`${posts.length} 篇文章 / ${categories.length} 个分类 / ${tags.length} 个标签`}
					icon="material-symbols:article-outline"
					hoverTitle="内容索引"
					hoverCode="02"
					variant="wide"
					pills={articlePills}
					statKind="articles"
					visualImage="/assets/images/home/home-data-2.webp"
				/>
			</div>

			<div class="home-data-layer__row home-data-layer__row--band">
				<section class="data-band data-band--contact" aria-labelledby="home-contact-title">
					<div class="data-band__intro">
						<div class="data-band__frame"></div>
						<div class="data-band__visual" aria-hidden="true">
							<img src="/assets/images/home/home-data-3.webp" alt="" class="data-band__visual-img" loading="lazy" decoding="async" />
						</div>
						<div class="data-band__content">
							<p class="data-band__eyebrow">CONTACT</p>
							<h3 id="home-contact-title">社交联系</h3>
							<p>把散落的入口收束在一条缓慢移动的轨道里。</p>
						</div>
					</div>
					<div class="data-band__loop">
						<LogoLoop
							client:load
							items={socialItems}
							speed={86}
							logoHeight={34}
							gap={18}
							hoverSpeed={0}
							fadeOut
							ariaLabel="社交联系方式"
							clickable
							showLabel
						/>
					</div>
				</section>
			</div>

			<div class="home-data-layer__row home-data-layer__row--band">
				<section class="data-band data-band--skills" aria-labelledby="home-skills-title">
					<div class="data-band__intro">
						<div class="data-band__frame"></div>
						<div class="data-band__visual" aria-hidden="true">
							<img src="/assets/images/home/home-data-4.webp" alt="" class="data-band__visual-img" loading="lazy" decoding="async" />
						</div>
						<div class="data-band__content">
							<p class="data-band__eyebrow">SKILLS</p>
							<h3 id="home-skills-title">技能图标</h3>
							<p>工程、内容和部署工具在同一条轨道上循环。</p>
						</div>
					</div>
					<div class="data-band__loop">
						<LogoLoop
							client:load
							items={skillItems}
							speed={74}
							direction="right"
							logoHeight={44}
							gap={26}
							hoverSpeed={0}
							fadeOut
							ariaLabel="技能图标"
							showLabel={false}
						/>
					</div>
				</section>
			</div>
		</div>
	</div>
</section>

<script>
	import { gsap } from "gsap";
	import { formatCompactNumber } from "@/utils/home-data-layer.js";

	type Cleanup = () => void;

	let cleanups: Cleanup[] = [];

	function cleanupHomeDataLayer() {
		cleanups.forEach((cleanup) => cleanup());
		cleanups = [];
	}

	function initVisitStats() {
		const layer = document.getElementById("home-data-layer");
		if (!layer) return;
		const detail = layer.querySelector(".data-card[data-stat-kind='visits'] .data-card__detail");
		const valueNodes = layer.querySelectorAll<HTMLElement>("[data-stat-value]");
		fetch("/api/count", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({ path: location.pathname }),
		})
			.then((response) => response.json())
			.then((data) => {
				const uv = formatCompactNumber(data.uv);
				const pv = formatCompactNumber(data.pv);
				if (detail) detail.textContent = `访客 ${uv} / 浏览 ${pv}`;
				valueNodes.forEach((node) => {
					const key = node.dataset.statValue;
					if (key === "UV") node.textContent = uv;
					if (key === "PV") node.textContent = pv;
				});
			})
			.catch(() => {
				if (detail) detail.textContent = "访客 -- / 浏览 --";
			});
	}

	function initMetricCards() {
		const layer = document.getElementById("home-data-layer");
		if (!layer) return;
		const canHover = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
		const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		if (!canHover || reduceMotion) return;

		const cards = Array.from(layer.querySelectorAll<HTMLElement>("[data-card-interactive]"));
		cards.forEach((card) => {
			const hover = card.querySelector<HTMLElement>(".data-card__hover");
			const orb = card.querySelector<HTMLElement>(".data-card__hover-orb");
			const header = card.querySelector<HTMLElement>(".data-card__hover-header");
			const title = card.querySelector<HTMLElement>(".data-card__hover-title");
			const pills = Array.from(card.querySelectorAll<HTMLElement>(".data-card__hover-pill"));
			if (!hover || !orb || !header || !title || pills.length === 0) return;

			const timeline = gsap.timeline({ paused: true, defaults: { ease: "power3.out" } });
			timeline
				.set(hover, { autoAlpha: 1 })
				.fromTo(orb, {
					xPercent: -50,
					yPercent: -50,
					scale: 0.18,
				}, {
					xPercent: -50,
					yPercent: -50,
					scale: 1,
					duration: 0.58,
					ease: "expo.out",
				}, 0)
				.fromTo([header, title], {
					autoAlpha: 0,
					y: 18,
				}, {
					autoAlpha: 1,
					y: 0,
					duration: 0.28,
					stagger: 0.05,
				}, 0.38)
				.fromTo(pills, {
					autoAlpha: 0,
					y: -44,
					scale: 0.82,
				}, {
					autoAlpha: 1,
					y: 0,
					scale: 1,
					duration: 0.44,
					stagger: 0.08,
					ease: "back.out(1.7)",
				}, 0.5);

			const enter = () => timeline.play();
			const leave = () => timeline.reverse();
			card.addEventListener("pointerenter", enter);
			card.addEventListener("pointerleave", leave);
			cleanups.push(() => {
				card.removeEventListener("pointerenter", enter);
				card.removeEventListener("pointerleave", leave);
				timeline.kill();
			});
		});
	}

	function initHomeDataLayer() {
		cleanupHomeDataLayer();
		initVisitStats();
		initMetricCards();
	}

	initHomeDataLayer();
	document.addEventListener("astro:page-load", initHomeDataLayer);
	document.addEventListener("swup:willReplaceContent", cleanupHomeDataLayer);
</script>
