---
import { getCategoryList } from "@/utils/content-utils";

const categories = await getCategoryList();
---

<div id="category-sticky-placeholder">
	<div id="category-sticky-wrapper">
		<div class="flex flex-wrap gap-2 px-2 max-w-full overflow-x-auto">
			{categories.map((c) => (
				<a href={c.url} aria-label={`View all posts in ${c.name.trim()}`} class="cat-square-btn text-sm gap-2 shrink-0">
					<span>{c.name.trim()}</span>
					<span class="text-(--content-meta) text-xs">{c.count}</span>
				</a>
			))}
		</div>
	</div>
</div>

<style>
	/* Category bar — fixed when scrolled past, follows header like TOC */
	#category-sticky-placeholder {
		position: relative;
		margin-bottom: 1rem;
	}
	#category-sticky-wrapper {
		position: relative;
		z-index: 40;
		background: transparent;
		padding: 0.5rem 0;
	}
	#category-sticky-wrapper.is-pinned {
		position: fixed;
		top: 68px;
		left: max(1rem, calc((100vw - 56rem) / 2));
		right: max(1rem, calc((100vw - 56rem) / 2));
		max-width: 56rem;
	}

	.cat-square-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.375rem 1rem;
		border: 1px solid rgba(0, 0, 0, 0.1);
		color: var(--deep-text);
		background: rgba(255, 255, 255, 0.6);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-radius: 9999px;
		transition: color 150ms, background-color 150ms, border-color 150ms;
		box-sizing: border-box;
	}
	.cat-square-btn:hover {
		background: rgba(0, 0, 0, 0.8);
		border-color: transparent;
		color: white;
	}
	:root.dark .cat-square-btn {
		border-color: rgba(255, 255, 255, 0.1);
		color: var(--deep-text);
		background: rgba(255, 255, 255, 0.08);
	}
	:root.dark .cat-square-btn:hover {
		background: rgba(255, 255, 255, 0.85);
		border-color: transparent;
		color: black;
	}
</style>

<script>
(function() {
	const FIXED_TOP = 68;
	let originalTop = 0;
	let ticking = false;

	function measure() {
		const placeholder = document.getElementById('category-sticky-placeholder');
		if (!placeholder) return;
		const rect = placeholder.getBoundingClientRect();
		originalTop = rect.top + window.scrollY;
	}

	function onScroll() {
		if (ticking) return;
		ticking = true;
		requestAnimationFrame(() => {
			const wrapper = document.getElementById('category-sticky-wrapper');
			const placeholder = document.getElementById('category-sticky-placeholder');
			const mainGrid = document.getElementById('main-grid');
			if (!wrapper || !placeholder || !mainGrid) { ticking = false; return; }

			const gridRect = mainGrid.getBoundingClientRect();
			const gridBottom = gridRect.bottom;
			const shouldPin = window.scrollY >= originalTop - FIXED_TOP && gridBottom > FIXED_TOP + wrapper.offsetHeight;

			if (shouldPin && !wrapper.classList.contains('is-pinned')) {
				placeholder.style.height = placeholder.offsetHeight + 'px';
			} else if (!shouldPin && wrapper.classList.contains('is-pinned')) {
				placeholder.style.height = '';
			}
			wrapper.classList.toggle('is-pinned', shouldPin);
			ticking = false;
		});
	}

	function init() {
		const wrapper = document.getElementById('category-sticky-wrapper');
		if (!wrapper) return;
		wrapper.classList.remove('is-pinned');
		requestAnimationFrame(() => {
			measure();
			window.addEventListener('scroll', onScroll, { passive: true });
			onScroll();
		});
	}

	function cleanup() {
		window.removeEventListener('scroll', onScroll);
		const wrapper = document.getElementById('category-sticky-wrapper');
		const placeholder = document.getElementById('category-sticky-placeholder');
		if (wrapper) wrapper.classList.remove('is-pinned');
		if (placeholder) placeholder.style.height = '';
	}

	init();
	window.addEventListener('resize', () => { measure(); onScroll(); });

	document.addEventListener('swup:page:view', () => { cleanup(); setTimeout(init, 100); });
	document.addEventListener('astro:page-load', () => { cleanup(); setTimeout(init, 100); });
})();
</script>
